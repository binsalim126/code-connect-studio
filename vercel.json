{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/server",
  "devCommand": "npm run dev",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
